{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "uview-ui/components/u-$1/u-$1.vue",
			"^uni-(.*)": "@/uni_modules/uni-$1/components/uni-$1/uni-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/home/index",
			"meta": {
				"loginAuth": false
			},
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/login/login",
			"meta": {
				"loginAuth": false
			},
			"style": {
				"navigationBarTitleText": "登录"
			}
		},
		{
			"path": "pages/chat/index",
			"meta": {
				"loginAuth": true
			},
			"style": {
				"navigationBarTitleText": "对话",
				"enablePullDownRefresh": true,
				"usingComponents": {
					"van-search": "/static/wxcomponents/vant-weapp/search/index"
				}
			}
		},
		{
			"path": "pages/requirement/index",
			"meta": {
				"loginAuth": true
			},
			"style": {
				"navigationBarTitleText": "需求",
				"enablePullDownRefresh": true,
				"usingComponents": {
					"van-notice-bar": "/static/wxcomponents/vant-weapp/notice-bar/index"
				}
			}
		},
		{
			"path": "pages/business/index",
			"meta": {
				"loginAuth": true
			},
			"style": {
				"navigationBarTitleText": "商业",
				"enablePullDownRefresh": true,
				"usingComponents": {
					"van-notice-bar": "/static/wxcomponents/vant-weapp/notice-bar/index"
				}
			}
		},
		{
			"path": "pages/mine/index",
			"meta": {
				"loginAuth": true
			},
			"style": {
				"navigationBarTitleText": "我的",
				"usingComponents": {
					"van-icon": "/static/wxcomponents/vant-weapp/icon/index"
				}
			}
		}
	],
	"subPackages": [
		{
			"root": "subpkg/home",
			"pages": [
				{
					"path": "index",
					"meta": {
						"loginAuth": false
					},
					"style": {
						"navigationBarTitleText": "Kinit 移动端框架"
					}
				}
			]
		},
		{
			"root": "subpkg/mine",
			"pages": [
				{
					"path": "avatar/index",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "修改头像"
					}
				},
				{
					"path": "info/index",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "个人信息"
					}
				},
				{
					"path": "info/edit",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "编辑资料"
					}
				},
				{
					"path": "pwd/index",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "修改密码"
					}
				},
				{
					"path": "setting/index",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "应用设置"
					}
				},
				{
					"path": "help/issue/index",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "常见问题"
					}
				},
				{
					"path": "help/issue/info",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "常见问题详情"
					}
				},
				{
					"path": "about/index",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "关于我们"
					}
				}
			]
		},
		{
			"root": "subpkg/common",
			"pages": [
				{
					"path": "webview/index",
					"meta": {
						"loginAuth": false
					},
					"style": {
						"navigationBarTitleText": "浏览网页"
					}
				},
				{
					"path": "textview/index",
					"meta": {
						"loginAuth": false
					},
					"style": {
						"navigationBarTitleText": "浏览文本"
					}
				}
			]
		},
		{
			"root": "subpkg/chat",
			"pages": [
				{
					"path": "chat",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "对话",
						"usingComponents": {
							"van-notice-bar": "/static/wxcomponents/vant-weapp/notice-bar/index"
						}
					}
				},
				{
					"path": "staff-inbox",
					"meta": {
						"loginAuth": true
					},
					"style": {
						"navigationBarTitleText": "客服接待",
						"enablePullDownRefresh": true,
						"usingComponents": {
							"van-search": "/static/wxcomponents/vant-weapp/search/index"
						}
					}
				}
			]
		}
	],
	"preloadRule": {
		"pages/mine/index": {
			"network": "all",
			"packages": ["subpkg/mine"]
		}
	},
	"tabBar": {
		"custom": true,
		"color": "#6B6B6B",
		"selectedColor": "#1E3A5F",
		"borderStyle": "white",
		"backgroundColor": "#FFFFFF",
		"list": [
			{
				"pagePath": "pages/home/index",
				"text": "首页"
			},
			{
				"pagePath": "pages/chat/index",
				"text": "话题"
			},
			{
				"pagePath": "pages/requirement/index",
				"text": "需求"
			},
			{
				"pagePath": "pages/business/index",
				"text": "商业"
			},
			{
				"pagePath": "pages/mine/index",
				"text": "我的"
			}
		]
	},
	"globalStyle": {
		"navigationStyle": "custom",
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "Kinit",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#F4F6F9",
		"app-plus": {
			"titleNView": false
		}
	}
}
