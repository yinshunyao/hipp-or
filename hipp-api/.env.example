# 复制为 .env 后填写真实连接信息（.env 已加入 .gitignore，勿提交）
#
# HTTP 服务绑定（uvicorn；未设置时使用默认值）
# HIPP_BIND_HOST=0.0.0.0
# HIPP_BIND_PORT=9000
#
# 调试模式：true/1/yes/on 开启；false/0/no/off 关闭。影响选用 development/production 配置、异常详情等。生产务必关闭。
# HIPP_DEBUG=false
#
# 演示模式：为 true 时除白名单外禁止 POST/PUT/DELETE 等写操作（返回「演示环境，禁止操作」）。本地开发或正式环境可关闭。
# HIPP_DEMO=false
# 可使用 mysql+pymysql:// 或 mysql+asyncmy://；应用运行时会自动转为 asyncmy，Alembic 会转为 pymysql。
# 密码含 @、:、% 等时：在 URL 中须做百分号编码（@ -> %40，: -> %3A，% -> %25），
# 或改用下面「分项配置」，密码可写明文，无需编码。
# HIPP_DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE
#
# 分项配置（与 HIPP_DATABASE_URL 二选一；设置 URL 时忽略此项）
# HIPP_DATABASE_HOST=127.0.0.1
# HIPP_DATABASE_PORT=3306
# HIPP_DATABASE_NAME=hipp
# HIPP_DATABASE_USER=root
# HIPP_DATABASE_PASSWORD=你的明文密码可含@符号

# 是否启用 MongoDB（可选）。未设置时沿用 application/config/*.py 中的 MONGO_DB_ENABLE。
# 设为 false / 0 / no 等则关闭 Mongo，操作审计与定时任务走 MySQL（须已配置 HIPP_DATABASE_URL 并完成迁移）。
# MONGO_DB_ENABLE=false

# Redis：启用时（默认见 application/config/*.py 中 REDIS_DB_ENABLE）必须配置 HIPP_REDIS_URL。
# 关闭 Redis：REDIS_DB_ENABLE=false（与 MONGO_DB_ENABLE 同样支持 true/false、1/0、yes/no 等）
# 无密码示例：
# HIPP_REDIS_URL=redis://127.0.0.1:6379/0
# 有密码示例（注意 redis://:密码@ 中的冒号）：
# HIPP_REDIS_URL=redis://:YOUR_PASSWORD@127.0.0.1:6379/1
# TLS 使用 rediss:// 前缀。
# REDIS_DB_ENABLE=true
# HIPP_REDIS_URL=redis://127.0.0.1:6379/0
#
# 智能客服「测试」调用 Dify 时，httpx 是否校验 HTTPS 证书。内网自签可设为 false（仅建议开发/内网）。
# HIPP_DIFY_HTTPX_VERIFY=true
#
# 阿里云短信（验证码登录、发送验证码、后台初始化密码短信等）。须与控制台短信签名、模板 CODE 一致。
# HIPP_SMS_ACCESS_KEY=
# HIPP_SMS_ACCESS_KEY_SECRET=
# HIPP_SMS_SIGN_NAME=
# HIPP_SMS_TEMPLATE_CODE=
# 重置密码通知短信（另一模板，模板变量一般为 password）；签名可省略，省略时沿用 HIPP_SMS_SIGN_NAME
# HIPP_SMS_SIGN_NAME_RESET=
# HIPP_SMS_TEMPLATE_CODE_RESET=
# 同一手机号发送间隔（秒）、验证码 Redis 有效期（秒）
# HIPP_SMS_SEND_INTERVAL=60
# HIPP_SMS_VALID_TIME=300
